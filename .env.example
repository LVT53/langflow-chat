LANGFLOW_API_URL=http://localhost:7860
LANGFLOW_API_KEY=your-api-key-here
LANGFLOW_FLOW_ID=your-flow-id-here
LANGFLOW_WEBHOOK_SECRET=
TRANSLATOR_URL=http://192.168.1.96:30002/v1
TRANSLATOR_API_KEY=
TRANSLATOR_MODEL=Infomaniak-AI/vllm-translategemma-12b-it
TRANSLATION_MAX_TOKENS=256
TRANSLATION_TEMPERATURE=0.1
TITLE_GEN_URL=http://192.168.1.96:30001/v1
TITLE_GEN_API_KEY=
TITLE_GEN_MODEL=nemotron-nano
WEBHOOK_PORT=8090
REQUEST_TIMEOUT_MS=120000
MAX_MESSAGE_LENGTH=10000
SESSION_SECRET=change-me-to-random-64-char-string
DATABASE_PATH=./data/chat.db

# Model 1 Configuration (default)
MODEL_1_BASEURL=http://192.168.1.96:30001/v1
MODEL_1_API_KEY=your-api-key-here
MODEL_1_NAME=nemotron-nano
MODEL_1_DISPLAY_NAME="Nemotron Nano"
# System prompt reference - options: alfyai-nemotron, hermes-thinking, default
MODEL_1_SYSTEM_PROMPT=alfyai-nemotron
# Optional: dedicated Langflow flow for this model.
# If unset, falls back to the global LANGFLOW_FLOW_ID above.
MODEL_1_FLOW_ID=

# Model 2 Configuration
MODEL_2_BASEURL=http://192.168.1.96:30002/v1
MODEL_2_API_KEY=your-api-key-here
MODEL_2_NAME=translategemma
MODEL_2_DISPLAY_NAME="TranslateGemma"
# System prompt reference - options: alfyai-nemotron, hermes-thinking, default
MODEL_2_SYSTEM_PROMPT=hermes-thinking
# Optional: dedicated Langflow flow for this model.
# If unset, falls back to the global LANGFLOW_FLOW_ID above.
MODEL_2_FLOW_ID=

# Honcho Memory System
# Cross-conversation long-term memory via self-hosted Honcho
HONCHO_ENABLED=false
HONCHO_API_KEY=
HONCHO_BASE_URL=http://localhost:8000
HONCHO_WORKSPACE=alfyai-prod
