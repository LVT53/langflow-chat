# Core runtime
LANGFLOW_API_URL=http://localhost:7860
LANGFLOW_API_KEY=your-langflow-api-key
LANGFLOW_FLOW_ID=your-default-flow-id
LANGFLOW_WEBHOOK_SECRET=
# Optional bearer key for /api/chat/files/generate when Langflow calls it outside the browser session
ALFYAI_API_KEY=
SESSION_SECRET=change-me-to-a-random-long-secret
DATABASE_PATH=./data/chat.db
# adapter-node listen address for host-managed deployments
HOST=127.0.0.1
PORT=3001
WEBHOOK_PORT=8090
REQUEST_TIMEOUT_MS=120000
MAX_MESSAGE_LENGTH=10000
ATTACHMENT_TRACE_DEBUG=false

# Primary model endpoint
MODEL_1_BASEURL=http://localhost:30001/v1
MODEL_1_API_KEY=
MODEL_1_NAME=nemotron-nano
MODEL_1_DISPLAY_NAME=Nemotron Nano
MODEL_1_SYSTEM_PROMPT=
# If empty, falls back to LANGFLOW_FLOW_ID
MODEL_1_FLOW_ID=
# Optional Langflow component/node ID to receive model tweaks
MODEL_1_COMPONENT_ID=

# Secondary model endpoint
MODEL_2_BASEURL=http://localhost:30002/v1
MODEL_2_API_KEY=
MODEL_2_NAME=translategemma
MODEL_2_DISPLAY_NAME=TranslateGemma
MODEL_2_SYSTEM_PROMPT=
# If empty, falls back to LANGFLOW_FLOW_ID
MODEL_2_FLOW_ID=
# Optional Langflow component/node ID to receive model tweaks
MODEL_2_COMPONENT_ID=
MODEL_2_ENABLED=true

# Translation
TRANSLATOR_URL=http://localhost:30002/v1
TRANSLATOR_API_KEY=
TRANSLATOR_MODEL=translategemma
TRANSLATION_MAX_TOKENS=256
TRANSLATION_TEMPERATURE=0.1

# Title generation
TITLE_GEN_URL=http://localhost:30001/v1
TITLE_GEN_API_KEY=
TITLE_GEN_MODEL=nemotron-nano
TITLE_GEN_SYSTEM_PROMPT_EN=
TITLE_GEN_SYSTEM_PROMPT_HU=
TITLE_GEN_SYSTEM_PROMPT_CODE_APPENDIX_EN=
TITLE_GEN_SYSTEM_PROMPT_CODE_APPENDIX_HU=

# Optional dedicated context summarizer
# If left empty, the app falls back to TITLE_GEN_URL / TITLE_GEN_API_KEY.
CONTEXT_SUMMARIZER_URL=
CONTEXT_SUMMARIZER_API_KEY=
CONTEXT_SUMMARIZER_MODEL=

# Optional Honcho-backed long-term memory
HONCHO_ENABLED=false
HONCHO_API_KEY=
HONCHO_BASE_URL=http://localhost:8000
HONCHO_WORKSPACE=alfyai-prod
HONCHO_CONTEXT_WAIT_MS=3000
HONCHO_CONTEXT_POLL_INTERVAL_MS=250
HONCHO_PERSONA_CONTEXT_WAIT_MS=1500
HONCHO_OVERVIEW_WAIT_MS=10000
MEMORY_MAINTENANCE_INTERVAL_MINUTES=0

# Optional: Context token limits (defaults: 262144, 209715, 157286)
# MAX_MODEL_CONTEXT=262144
# COMPACTION_UI_THRESHOLD=209715
# TARGET_CONSTRUCTED_CONTEXT=157286
