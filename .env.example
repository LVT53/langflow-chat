# Core runtime
LANGFLOW_API_URL=http://localhost:7860
LANGFLOW_API_KEY=your-langflow-api-key
LANGFLOW_FLOW_ID=your-default-flow-id
LANGFLOW_WEBHOOK_SECRET=
# Required for signed service assertions on /api/chat/files/generate
ALFYAI_API_SIGNING_KEY=
SESSION_SECRET=change-me-to-a-random-long-secret
DATABASE_PATH=./data/chat.db
# adapter-node listen address for host-managed deployments
HOST=127.0.0.1
PORT=3001
WEBHOOK_PORT=8090
REQUEST_TIMEOUT_MS=300000
MAX_MESSAGE_LENGTH=10000
ATTACHMENT_TRACE_DEBUG=false

# Primary model endpoint
MODEL_1_BASEURL=http://localhost:30001/v1
MODEL_1_API_KEY=
MODEL_1_NAME=nemotron-nano
MODEL_1_DISPLAY_NAME=Nemotron Nano
MODEL_1_SYSTEM_PROMPT=
# If empty, falls back to LANGFLOW_FLOW_ID
MODEL_1_FLOW_ID=
# Optional Langflow component/node ID to receive model tweaks
MODEL_1_COMPONENT_ID=

# Secondary model endpoint
MODEL_2_BASEURL=http://localhost:30002/v1
MODEL_2_API_KEY=
MODEL_2_NAME=translategemma
MODEL_2_DISPLAY_NAME=TranslateGemma
MODEL_2_SYSTEM_PROMPT=
# If empty, falls back to LANGFLOW_FLOW_ID
MODEL_2_FLOW_ID=
# Optional Langflow component/node ID to receive model tweaks
MODEL_2_COMPONENT_ID=
MODEL_2_ENABLED=true

# Translation
TRANSLATOR_URL=http://localhost:30002/v1
TRANSLATOR_API_KEY=
TRANSLATOR_MODEL=translategemma
TRANSLATION_MAX_TOKENS=256
TRANSLATION_TEMPERATURE=0.1

# Title generation
TITLE_GEN_URL=http://localhost:30001/v1
TITLE_GEN_API_KEY=
TITLE_GEN_MODEL=nemotron-nano
TITLE_GEN_SYSTEM_PROMPT_EN=
TITLE_GEN_SYSTEM_PROMPT_HU=
TITLE_GEN_SYSTEM_PROMPT_CODE_APPENDIX_EN=
TITLE_GEN_SYSTEM_PROMPT_CODE_APPENDIX_HU=

# Optional dedicated context summarizer
# If left empty, the app falls back to TITLE_GEN_URL / TITLE_GEN_API_KEY.
CONTEXT_SUMMARIZER_URL=
CONTEXT_SUMMARIZER_API_KEY=
CONTEXT_SUMMARIZER_MODEL=

# Optional Hugging Face Text Embeddings Inference clients
# Typical models: bge-m3 (embedder) and bge-reranker-v2-m3 (reranker)
TEI_EMBEDDER_URL=
TEI_EMBEDDER_API_KEY=
TEI_EMBEDDER_MODEL=
TEI_EMBEDDER_BATCH_SIZE=32
TEI_RERANKER_URL=
TEI_RERANKER_API_KEY=
TEI_RERANKER_MODEL=
TEI_RERANKER_MAX_TEXTS=32
TEI_TIMEOUT_MS=120000

# Optional Honcho-backed long-term memory
HONCHO_ENABLED=false
HONCHO_API_KEY=
HONCHO_BASE_URL=http://localhost:8000
HONCHO_WORKSPACE=alfyai-prod
# Optional. If empty, derived from HONCHO_WORKSPACE + DATABASE_PATH so separate DBs
# do not share Honcho peers/sessions even inside the same workspace.
HONCHO_IDENTITY_NAMESPACE=
HONCHO_CONTEXT_WAIT_MS=3000
HONCHO_CONTEXT_POLL_INTERVAL_MS=250
HONCHO_PERSONA_CONTEXT_WAIT_MS=1500
HONCHO_OVERVIEW_WAIT_MS=10000
MEMORY_MAINTENANCE_INTERVAL_MINUTES=0

# Document extraction / OCR
# Liteparse powers upload normalization for PDF, Office docs, and images.
# Leave DOCUMENT_PARSER_OCR_SERVER_URL empty to use Liteparse built-in OCR (Tesseract path).
# Set DOCUMENT_PARSER_OCR_SERVER_URL only when using an external OCR server contract.
# Optional Paddle bridge example:
#   DOCUMENT_PARSER_OCR_SERVER_URL=http://127.0.0.1:3000/api/ocr/paddle
#   DOCUMENT_PARSER_PADDLE_BACKEND_URL=http://127.0.0.1:5000/ocr
DOCUMENT_PARSER_OCR_ENABLED=true
DOCUMENT_PARSER_OCR_SERVER_URL=
DOCUMENT_PARSER_PADDLE_BACKEND_URL=
# Built-in Tesseract prefers ISO-639-3 style codes (hun/eng/nld).
DOCUMENT_PARSER_OCR_LANGUAGE=hun+eng+nld
DOCUMENT_PARSER_NUM_WORKERS=3
DOCUMENT_PARSER_MAX_PAGES=300
DOCUMENT_PARSER_DPI=180
DOCUMENT_PARSER_TIMEOUT_MS=120000

# Brave Search API (image search tool)
BRAVE_SEARCH_API_KEY=

# Optional: Context token limits (defaults: 262144, 209715, 157286)
# MAX_MODEL_CONTEXT=262144
# COMPACTION_UI_THRESHOLD=209715
# TARGET_CONSTRUCTED_CONTEXT=157286

# Optional: Concurrent request limits (defaults: 3 global, 1 per-user)
# Limits how many simultaneous chat requests the server accepts
# CONCURRENT_STREAM_LIMIT=3
# PER_USER_STREAM_LIMIT=1
