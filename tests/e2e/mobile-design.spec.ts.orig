import { test, expect } from '@playwright/test';

// Use iPhone SE (375x667)
test.use({ 
  viewport: { width: 375, height: 667 },
  hasTouch: true,
  isMobile: true,
  userAgent: 'Mozilla/5.0 (iPhone; CPU iPhone OS 16_6 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.6 Mobile/15E148 Safari/604.1'
});

test.describe('Mobile Design Polish', () => {
  
  test.beforeEach(async ({ page }) => {
    await page.goto('/');
    
    // Check if we are redirected to login
    if (page.url().includes('/login')) {
      await page.fill('input[name="email"]', 'admin@local');
      await page.fill('input[name="password"]', 'admin123');
      await page.click('button[type="submit"]');
      await page.waitForURL('**/', { timeout: 5000 }).catch(() => {});
    }
  });

  test('Layout and Touch Targets - iPhone SE', async ({ page }) => {
    // Header should be 48px height
    const header = page.locator('header');
    await expect(header).toBeVisible();
    const headerBox = await header.boundingBox();
    expect(headerBox?.height).toBe(48);

    // Hamburger menu button should be 44x44
    const hamburger = page.locator('button[aria-label="Toggle sidebar"]');
    const hamburgerBox = await hamburger.boundingBox();
    expect(hamburgerBox?.width).toBe(44);
    expect(hamburgerBox?.height).toBe(44);

    // New Chat button should be 44x44
    const newChatBtn = page.locator('button[aria-label="New chat"]');
    const newChatBox = await newChatBtn.boundingBox();
    expect(newChatBox?.width).toBe(44);
    expect(newChatBox?.height).toBe(44);

    // Sidebar should be hidden by default on mobile
    const sidebar = page.locator('aside');
    await expect(sidebar).toHaveClass(/.*-translate-x-full.*/);

    // Open sidebar
    await hamburger.click();
    await page.waitForTimeout(300); // wait for animation
    
    // Sidebar should slide in
    await expect(sidebar).toHaveClass(/.*translate-x-0.*/);

    // Close button in sidebar should be 44x44
    const closeBtn = page.locator('button[aria-label="Close sidebar"]');
    const closeBox = await closeBtn.boundingBox();
    expect(closeBox?.width).toBe(44);
    expect(closeBox?.height).toBe(44);

    // Close sidebar
    await closeBtn.click();
    await page.waitForTimeout(300);
  });

  test('Chat Area & Input Area', async ({ page }) => {
    // Start a new chat
    await page.waitForLoadState('networkidle');
    await page.waitForTimeout(500); // Wait for Svelte hydration
    await page.waitForSelector('button:has-text("New Conversation")');
    await page.click('button:has-text("New Conversation")');
    await page.waitForURL('**/chat/**');

    // Send a message
    const textarea = page.locator('textarea[placeholder="Type a message..."]');
    await expect(textarea).toBeVisible();
    
    // Check input area minimum height
    const textareaBox = await textarea.boundingBox();
    expect(textareaBox?.height).toBeGreaterThanOrEqual(44);

    // Send button should be 44x44
    const sendBtn = page.locator('button[aria-label="Send message"]');
    const sendBox = await sendBtn.boundingBox();
    expect(sendBox?.width).toBe(44);
    expect(sendBox?.height).toBe(44);

    // Attach button should be 44x44
    const attachBtn = page.locator('button[aria-label="Attach file"]');
    const attachBox = await attachBtn.boundingBox();
    expect(attachBox?.width).toBe(44);
    expect(attachBox?.height).toBe(44);

    // Type a long message to see if it scrolls
    await textarea.fill('```python\ndef test_horizontal_scroll_with_a_very_long_line_of_code_that_should_wrap_or_scroll_horizontally():\n    return "This string is exceptionally long and will definitely trigger horizontal scrolling on a small screen like the iPhone SE"\n```');
    await sendBtn.click();

    // Wait for the assistant to reply (mock streaming might take a sec)
    await page.waitForTimeout(2000);

    // User message bubble should not exceed 85% of viewport width (approx 318px on 375px screen)
    // Actually tailwind class max-w-[85%] is applied.
    const userMessage = page.locator('div.max-w-\\[85\\%\\]');
    await expect(userMessage.first()).toBeVisible();
    const userBox = await userMessage.first().boundingBox();
    expect(userBox?.width).toBeLessThanOrEqual(375 * 0.86); // adding slight margin of error

    // Code block horizontal scroll
    const preBlock = page.locator('.prose pre').first();
    await expect(preBlock).toBeVisible();
    
    // Check if pre block allows horizontal scroll
    const isScrollable = await preBlock.evaluate((node) => node.scrollWidth > node.clientWidth);
    expect(isScrollable).toBeTruthy();
    
    // Code block font size should be 14px
    const codeStyle = await preBlock.evaluate((node) => {
      const code = node.querySelector('code');
      if (!code) return null;
      return window.getComputedStyle(code).fontSize;
    });
    expect(codeStyle).toBe('14px');
  });

});

// Use iPhone 14 (390x844)
test.describe('Mobile Design Polish - iPhone 14', () => {
  test.use({ 
    viewport: { width: 390, height: 844 },
    hasTouch: true,
    isMobile: true,
    userAgent: 'Mozilla/5.0 (iPhone; CPU iPhone OS 16_6 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.6 Mobile/15E148 Safari/604.1'
  });

  test.beforeEach(async ({ page }) => {
    await page.goto('/');
    
    if (page.url().includes('/login')) {
      await page.fill('input[name="email"]', 'admin@local');
      await page.fill('input[name="password"]', 'admin123');
      await page.click('button[type="submit"]');
      await page.waitForURL('**/', { timeout: 5000 }).catch(() => {});
    }
  });

  test('Check prefers-reduced-motion', async ({ page }) => {
    // Test that the CSS handles reduced motion
    await page.emulateMedia({ reducedMotion: 'reduce' });
    
    const hamburger = page.locator('button[aria-label="Toggle sidebar"]');
    await hamburger.click();
    
    const sidebar = page.locator('aside');
    // On reduced motion, animations are effectively disabled/0.01ms
    const transitionDuration = await sidebar.evaluate((node) => {
      return window.getComputedStyle(node).transitionDuration;
    });
    
    expect(['0s', '0.00001s', '1e-05s']).toContain(transitionDuration);
  });
});
